# Curepay configuration — copy to .env and adjust.

# --- Data sources ---
# Drift Protocol public data API (read-only, no key required).
CUREPAY_DRIFT_API=https://data.api.drift.trade
# Solana RPC endpoint (public default; swap for a private RPC for reliability).
CUREPAY_SOLANA_RPC=https://api.mainnet-beta.solana.com
# CoinGecko spot price API (used as an index-price sanity fallback).
CUREPAY_COINGECKO_API=https://api.coingecko.com/api/v3

# --- Markets the agent watches (comma-separated Drift perp market names) ---
CUREPAY_MARKETS=SOL-PERP,BTC-PERP,ETH-PERP

# --- Strategy: funding-carry ---
# Annualised funding (abs) above which a carry signal is considered.
CUREPAY_MIN_ANNUAL_FUNDING=0.05
# Minimum |z-score| of funding vs its recent history to act.
CUREPAY_MIN_FUNDING_Z=1.0

# --- Risk ---
CUREPAY_EQUITY_USD=10000
CUREPAY_MAX_LEVERAGE=3
CUREPAY_RISK_PER_TRADE=0.02
CUREPAY_MAX_POSITIONS=3
# Halt trading if simulated equity drops this fraction below the peak.
CUREPAY_MAX_DRAWDOWN=0.2

# --- Execution ---
# paper = simulate only (default and the only mode shipped). No keys are read.
CUREPAY_MODE=paper

# --- Loop ---
CUREPAY_POLL_SECONDS=60
CUREPAY_LOG_LEVEL=INFO
